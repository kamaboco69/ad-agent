# ── Ad Agent 環境変数 ──

# Neon Postgres
DATABASE_URL="postgresql://user:pass@host/adagent?sslmode=require"

# 認証（NextAuth v5）
AUTH_SECRET=          # openssl rand -base64 32
AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# トークン暗号化（AES-256-GCM, 32byte hex = 64文字）
ENCRYPTION_KEY=       # openssl rand -hex 32

# AI インサイト生成
ANTHROPIC_API_KEY=

# cron 保護
CRON_SECRET=

# Googleログイン（x-step と同じ OAuth クライアントを流用可・任意）
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── 実API接続（設定した媒体のみ「API接続」ボタンが有効になる。未設定でもデモ接続で全機能を試せる） ──
# Google Ads API（開発者トークンは Basic access 以上の承認が必要）
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=

# Yahoo!広告 API（API利用申請の承認が必要）
YAHOO_ADS_CLIENT_ID=
YAHOO_ADS_CLIENT_SECRET=

# Meta Marketing API（Meta/Instagram 共通。ads_read/ads_management のアプリレビューが必要）
META_ADS_APP_ID=
META_ADS_APP_SECRET=

# X Ads API（アクセス申請承認後に対応予定）
X_ADS_CONSUMER_KEY=
X_ADS_CONSUMER_SECRET=

# TikTok Business API（開発者アプリ審査の承認が必要）
TIKTOK_ADS_APP_ID=
TIKTOK_ADS_APP_SECRET=
